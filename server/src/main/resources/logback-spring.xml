<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- File appender — ALL logs go here -->
    <appender name="FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${user.home}/.jarvis/logs/jarvis.log</file>
        <rollingPolicy
                class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>
                ${user.home}/.jarvis/logs/jarvis-%d{yyyy-MM-dd}.%i.log.gz
            </fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{40} - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- Console appender — ONLY warnings and errors -->
    <!-- This keeps the CLI clean during chat -->
    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root: INFO to file, WARN+ to console -->
    <root level="INFO">
        <appender-ref ref="FILE"/>
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Jarvis own classes: INFO to file only -->
    <logger name="ai.ultimate"
            level="INFO"
            additivity="false">
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Spring framework: WARN only -->
    <logger name="org.springframework"
            level="WARN"
            additivity="false">
        <appender-ref ref="FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

</configuration>